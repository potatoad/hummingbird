generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Junket {
  id          String    @id @default(uuid())
  name        String
  description String?
  location    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  days        Day[]
}

model Day {
  id                       String    @id @default(uuid())
  date                     DateTime  @db.Date
  greenroom                Boolean   @default(false)
  greenroomUrl             String?
  greenroomPassword        String?
  pressHospitalityURL      String?
  pressHospitalityID       String?
  pressHospitalityPassword String?
  junketId                 String
  junket                   Junket   @relation(fields: [junketId], references: [id], onDelete: Cascade)
  rooms                    Room[]
}

model Room {
  id               String     @id @default(uuid())
  colour           String     @default("#ffffff")
  name             String
  producer         String?
  timer            String?
  technician       String?
  streamURL        String?
  checkInBuffer    Int        @default(60)
  localTimeOffset  Int        @default(0)
  turnaround       Int        @default(60)
  plannedStartTime DateTime?
  actualStartTime  DateTime?
  plannedEndTime   DateTime?
  actualEndTime    DateTime?
  dayId            String
  day              Day       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  slots            Slot[]
}

model Slot {
  id               String     @id @default(uuid())
  title            String
  description      String?
  colour           String     @default("#ffffff")
  status           Status     @default(BLANK)
  isVirtual        Boolean    @default(false)
  slotType         SlotType   @default(INTERVIEW)
  checkInTime      DateTime?  @db.Timestamptz(6)
  plannedStartTime DateTime?  @db.Timestamptz(6)
  duration         Int?
  plannedEndTime   DateTime?  @db.Timestamptz(6)
  actualStartTime  DateTime?  @db.Timestamptz(6)
  actualEndTime    DateTime?  @db.Timestamptz(6)
  orderIndex       Float      @default(0)
  roomId           String
  room             Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

enum SlotType {
  TALENT
  INTERVIEW
  NOTE
  BUFFER
  BREAK
}

enum Status {
  BLANK
  ARRIVED
  WAITING
  INTERVIEW
  COMPLETED
  CANCELLED
}
